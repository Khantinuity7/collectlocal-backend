# Apify (free tier: $5 credits/month = ~1,000 listings)
APIFY_TOKEN=your_apify_api_token

# Supabase (free tier: 500MB, 50K rows)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# eBay Browse API (free, get keys at https://developer.ebay.com/my/keys)
# App ID (Client ID) = EBAY_CLIENT_ID
# Cert ID (Client Secret) = EBAY_CLIENT_SECRET
EBAY_CLIENT_ID=your_ebay_app_id
EBAY_CLIENT_SECRET=your_ebay_cert_id

# Your home location for distance calculation
HOME_LAT=32.9700
HOME_LNG=-96.7500

# Search configuration
SEARCH_LOCATION=Dallas, TX
SEARCH_RADIUS_MILES=40
