# ── Apify (free tier: $5 credits/month = ~1,000 listings) ──
APIFY_TOKEN=your_apify_api_token

# ── Supabase (free tier: 500MB, 50K rows) ──
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_ANON_KEY=your_anon_key

# ── GitHub (for push_files.py deployments) ──
# Create at: https://github.com/settings/tokens/new (check "repo" scope)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=Khantinuity7/collectlocal-backend

# ── eBay Browse API (free, get keys at https://developer.ebay.com/my/keys) ──
EBAY_CLIENT_ID=your_ebay_app_id
EBAY_CLIENT_SECRET=your_ebay_cert_id

# ── Google Gemini (free tier: 1,000 req/day for card identification) ──
GEMINI_API_KEY=your_gemini_api_key

# ── Location & Search ──
HOME_LAT=32.9700
HOME_LNG=-96.7500
SEARCH_LOCATION=Dallas, TX
SEARCH_RADIUS_MILES=40

# ── Firebase (for push notifications) ──
# FCM_SERVICE_ACCOUNT is base64-encoded service account JSON
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Then: base64 -i service-account.json | pbcopy
FCM_SERVICE_ACCOUNT=base64_encoded_service_account_json
